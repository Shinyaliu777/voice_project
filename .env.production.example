# ============================================================================
# Production environment template — copy values into your Vercel project
# settings (Project → Settings → Environment Variables).
#
# Do NOT commit a filled-in copy of this file. It's a template only.
# ============================================================================

# ---- Postgres (Neon recommended) ----
DATABASE_URL="postgresql://user:pass@host.neon.tech/voice_project?sslmode=require"

# ---- Soniox (required) ----
SONIOX_API_KEY=""

# ---- LLM (at least one) ----
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
LLM_DEFAULT_PROVIDER="gemini"
LLM_MINUTES_MODEL="gemini-2.5-flash"
LLM_CHAT_MODEL="claude-sonnet-4-6"
LLM_TRANSLATE_MODEL="gemini-2.5-flash"
LLM_TERM_EXTRACT_MODEL="gemini-2.5-flash"
LLM_FLASHCARD_MODEL="gemini-2.5-flash"

# ---- Storage (Cloudflare R2 recommended) ----
STORAGE_DRIVER="s3"
S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="voice-project"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE="https://<bucket>.<account>.r2.cloudflarestorage.com"

# ---- Redis (Upstash recommended; optional but live-share won't work cross-instance without it) ----
REDIS_URL=""

# ---- Phase 1 dev user (kept until Auth lands in wave 2) ----
DEV_USER_EMAIL="prod@voice.local"
