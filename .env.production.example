# ============================================================================
# Production environment template — for self-hosted Linux or managed
# (Vercel / Cloudflare Pages). On Vercel: copy values into Project →
# Settings → Environment Variables, do NOT commit a filled copy.
#
# Stars (*) mark variables that MUST have a real value.
# This file mirrors .env.example but flips a few defaults for prod
# (object storage instead of local filesystem; HTTPS callback URLs).
# ============================================================================


# ─── Postgres (Neon / Supabase / RDS recommended) ──────────────────────────
DATABASE_URL="postgresql://user:pass@host.neon.tech/voice_project?sslmode=require"   # *


# ─── Soniox ────────────────────────────────────────────────────────────────
SONIOX_API_KEY=""                          # *
SONIOX_MODEL="stt-rt-v4"
SONIOX_TOKEN_TTL_SECONDS=600
NEXT_PUBLIC_SONIOX_LANGUAGE_HINTS_STRICT="1"


# ─── LLM (at least one provider) ───────────────────────────────────────────
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
DEEPSEEK_API_KEY=""
LLM_DEFAULT_PROVIDER="gemini"
LLM_MINUTES_MODEL="gemini-2.5-flash"
LLM_CHAT_MODEL="claude-sonnet-4-6"
LLM_TRANSLATE_MODEL="gemini-2.5-flash"
LLM_TERM_EXTRACT_MODEL="gemini-2.5-flash"
LLM_FLASHCARD_MODEL="gemini-2.5-flash"


# ─── Storage — Cloudflare R2 (recommended for prod) ────────────────────────
STORAGE_DRIVER="s3"                                                    # *
S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_BUCKET="voice-project"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE="https://<bucket>.<account>.r2.cloudflarestorage.com"
# Used only when STORAGE_DRIVER=local (self-host with persistent volume)
# STORAGE_LOCAL_DIR="/var/lib/voice-project/uploads"


# ─── Upload + capture tuning ───────────────────────────────────────────────
UPLOAD_INTERVAL_MS=3000
TARGET_SAMPLE_RATE=16000


# ─── Auth (NextAuth v5) ────────────────────────────────────────────────────
AUTH_SECRET=""                             # *  openssl rand -base64 32
# Auth.js reads Host header by default (we set trustHost: true). Leave
# blank or set to your https domain for strictness.
NEXTAUTH_URL=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Resend magic-link email login. Universal fallback that works in EVERY
# browser including in-app webviews (微信 / QQ / 钉钉 / 抖音) where
# Google OAuth fails with disallowed_useragent. Free 3000 emails/month.
# Get key: https://resend.com/api-keys
# EMAIL_FROM requires a verified domain on resend.com for production
# (you can use onboarding@resend.dev for the first ~10 emails to your
# own verified email while setting DNS up).
RESEND_API_KEY=""
EMAIL_FROM="Voice Project <hi@voice.cyanclay.org>"
# Leave BLANK in prod unless you really know what you're doing — the
# auth.ts boot guard refuses to start if both Google + dev-login are
# enabled in production (account takeover vector).
ALLOW_DEV_LOGIN=""

# Phase-1 fallback — only used if some legacy unauthed route is still
# being exercised. Production: keep blank.
DEV_USER_EMAIL=""
DEV_USER_NAME=""
ALLOW_DEV_USER_FALLBACK=""


# ─── Referral attribution ──────────────────────────────────────────────────
REFERRAL_BONUS_MINUTES="60"


# ─── Admin console (/admin) ────────────────────────────────────────────────
# Project owner's email is already set in the committed `.env.production`
# file (loaded automatically by Next.js in prod builds). This example
# value is for ops to add ADDITIONAL admins via the gitignored
# `.env.production.local` file, e.g.:
#   ADMIN_EMAILS="shinyaliu777@gmail.com,ops@example.com"
# That file overrides the committed default. Case-insensitive.
ADMIN_EMAILS=""


# ─── Redis (multi-instance live-share fan-out) ─────────────────────────────
# Required if you run more than one Next.js process / pod / container
# behind a load balancer — without Redis, viewers connected to instance
# A miss frames pushed via instance B's host WS. Single-instance: blank
# is fine (in-memory pub/sub).
REDIS_URL=""


# ─── PostHog (self-hosted) ─────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""


# ─── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV="production"
