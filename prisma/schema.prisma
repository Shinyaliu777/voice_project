generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String    @id @default(cuid())
  email                   String    @unique
  emailVerified           DateTime?
  name                    String?
  /// NextAuth uses `image` for the OAuth profile picture; we keep our
  /// existing `avatarUrl` alias as well for backwards-compat with code that
  /// reads it. New code should prefer `image`.
  image                   String?
  avatarUrl               String?
  /// Free-form per-user UI/notification/floating-window preferences (JSON blob)
  settings                Json?
  /// Maximum concurrent recording slots ("active" RecordingSlot rows)
  /// this user may hold. Free plan = 1, future paid plans bump this via
  /// /api/recording/start logic. Stored on the user for now; once Stripe
  /// ships, derive from Subscription.plan in the route handler.
  maxConcurrentRecordings Int       @default(1)

  // ---- Referral attribution + reward ---------------------------------
  // Registration is always open. When a new user signs up via a link
  // carrying `?invite=CODE` (or types the code into the optional
  // field on /login), we stamp `invitedById` here AND bump
  // `referralBonusMinutes` on the inviter by REFERRAL_BONUS_MINUTES
  // (env, default 60). Self-invites (same email lowercased) get
  // attribution but skip the reward.
  invitedById          String?
  /// Extra monthly recording minutes earned via referrals, on TOP
  /// of the user's Plan-defined monthlyMinutes cap. Persists across
  /// months — once earned, never decays. Cap calc is in lib/quota.ts.
  referralBonusMinutes Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folders           Folder[]
  sessions          Session[]
  flashcards        Flashcard[]
  chatSessions      ChatSession[]
  liveShareSessions LiveShareSession[]
  polls             Poll[]
  pollVotes         PollVote[]
  recordingSlots    RecordingSlot[]

  // Invite relations (named so we can use User on both sides)
  invitedBy      User?        @relation("UserInvites", fields: [invitedById], references: [id])
  invitedUsers   User[]       @relation("UserInvites")
  createdInvites Invitation[] @relation("CreatedInvites")

  // ---- NextAuth -----------------------------------------------------
  // We use JWT session strategy so there's no separate Session table
  // (which would clash with our existing Session = recording-session
  // model below). Only Account + VerificationToken are needed.
  accounts Account[]

  // ---- Billing ------------------------------------------------------
  subscription Subscription?
}

// =========================================================
// NextAuth tables (Auth.js v5 spec)
// =========================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String // "oauth" | "email" | "credentials"
  provider          String // "google" | "apple" | …
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String // email being verified
  token      String // opaque magic-link token
  expires    DateTime

  @@unique([identifier, token])
}

// =========================================================
// Billing (mirrors lecsync's structure; see
// docs/LECSYNC_REVERSE_ENGINEERING.md §8 B)
// =========================================================

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model Plan {
  id                       String   @id @default(cuid())
  /// Internal slug, e.g. "free", "business"
  name                     String   @unique
  /// Customer-facing label, e.g. "Free", "Business"
  displayName              String
  description              String?
  monthlyPriceCents        Int      @default(0)
  yearlyPriceCents         Int      @default(0)
  /// Recording-time quota per calendar month. 999999 = effectively unlimited.
  monthlyMinutes           Int      @default(120)
  /// Chat messages per day cap. 0 = unlimited (handled in code).
  dailyChatMessages        Int      @default(20)
  cloudTranslationIncluded Boolean  @default(true)
  isPremium                Boolean  @default(false)
  isActive                 Boolean  @default(true)
  /// Newly registered users get the default plan as their initial Subscription.
  isDefault                Boolean  @default(false)
  /// Stripe price ids (filled in when admin links a plan to Stripe).
  stripePriceIdMonthly     String?
  stripePriceIdYearly      String?
  /// Apple IAP product ids (for the iOS app, if we ship one).
  appleProductIdMonthly    String?
  appleProductIdYearly     String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId               String
  plan                 Plan               @relation(fields: [planId], references: [id])
  status               SubscriptionStatus @default(ACTIVE)
  billingCycle         BillingCycle       @default(MONTHLY)
  currentPeriodStart   DateTime           @default(now())
  /// null for default/free plans that don't expire.
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  isStripeSubscription Boolean            @default(false)
  /// "default" (auto on signup) | "stripe" | "apple_iap" | "redemption" | "admin"
  subscriptionSource   String             @default("default")
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([planId])
}

model Folder {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  color                String?
  sourceLang           String?
  targetLang           String?
  /// Serialized list of terms used as Soniox `context` for sessions in this folder
  transcriptionContext String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions  Session[]
  documents Document[]

  // Duplicate folder names per user were already rejected in the POST
  // handler but only via a fetch-then-check race-condition pattern.
  // This makes uniqueness an invariant, eliminating the TOCTOU.
  @@unique([userId, name])
  @@index([userId])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  folderId         String?
  title            String   @default("")
  sourceLang       String
  targetLang       String
  status           String   @default("idle") // idle/recording/uploading/ready/error
  durationMs       Int?
  audioPath        String?
  audioContentType String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder            Folder?            @relation(fields: [folderId], references: [id], onDelete: SetNull)
  segments          Segment[]
  speakerNames      SpeakerName[]
  audioChunks       AudioChunk[]
  bookmarks         Bookmark[]
  minutes           Minutes?
  chatSessions      ChatSession[]
  flashcards        Flashcard[]
  liveShareSessions LiveShareSession[]

  @@index([userId])
  @@index([folderId])
  @@index([createdAt])
}

model Segment {
  id             String   @id @default(cuid())
  sessionId      String
  segmentIndex   Int
  audioStartMs   Int
  audioEndMs     Int
  speakerId      Int?
  sourceText     String   @db.Text
  translatedText String?  @db.Text
  confidence     Float?
  isFinal        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, segmentIndex])
  @@index([sessionId])
}

model SpeakerName {
  id        String   @id @default(cuid())
  sessionId String
  speakerId Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, speakerId])
}

model AudioChunk {
  id          String   @id @default(cuid())
  sessionId   String
  chunkIndex  Int
  sizeBytes   Int
  durationMs  Int
  contentType String
  storageKey  String
  publicUrl   String
  uploadedAt  DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, chunkIndex])
  @@index([sessionId])
}

model Bookmark {
  id        String   @id @default(cuid())
  sessionId String
  atMs      Int
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Minutes {
  id        String @id @default(cuid())
  sessionId String @unique

  // ---- Final (post-recording) minutes ----
  // Written by the explicit "生成纪要" button after recording stops.
  // Runs a full pass over the entire transcript so it can produce a
  // higher-quality, more structured summary than the live version.
  contentMd    String  @default("") @db.Text
  sectionsJson Json?
  model        String?
  status       String  @default("pending") // pending/streaming/done/error

  // ---- Live (incremental) minutes ----
  // Written during recording by the auto-refresh that fires every
  // ~2000 new chars. Captures the running narrative of the session as
  // it happens. Independent of the final fields above so the "纪要"
  // tab (final) and "实时纪要" tab (live) can show genuinely
  // different content.
  liveContentMd    String  @default("") @db.Text
  liveSectionsJson Json?
  liveModel        String?
  liveStatus       String  @default("pending") // pending/streaming/done/error

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Document {
  id               String   @id @default(cuid())
  folderId         String
  fileName         String
  fileType         String
  fileSize         Int
  storageKey       String
  blobUrl          String
  extractionStatus String   @default("pending") // pending/processing/done/failed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  folder         Folder          @relation(fields: [folderId], references: [id], onDelete: Cascade)
  extractedTerms ExtractedTerm[]

  @@index([folderId])
}

model ExtractedTerm {
  id         String   @id @default(cuid())
  documentId String
  term       String
  definition String?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  sessionId String?
  title     String   @default("Untitled")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session  Session?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId])
  @@index([sessionId])
}

model ChatMessage {
  id            String   @id @default(cuid())
  chatSessionId String
  role          String // user/assistant/system
  content       String   @db.Text
  partsJson     Json?
  createdAt     DateTime @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
}

model Flashcard {
  id              String   @id @default(cuid())
  userId          String
  sourceSessionId String?
  sourceSegmentId String?
  front           String   @db.Text
  back            String   @db.Text
  intervalDays    Int      @default(0)
  easeFactor      Float    @default(2.5)
  reviewCount     Int      @default(0)
  nextReviewAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session?          @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)
  reviews FlashcardReview[]

  @@index([userId])
  @@index([nextReviewAt])
}

model FlashcardReview {
  id          String   @id @default(cuid())
  flashcardId String
  rating      Int
  reviewedAt  DateTime @default(now())

  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@index([flashcardId])
}

model LiveShareSession {
  id        String   @id @default(cuid())
  sessionId String
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
}

model Poll {
  id          String   @id @default(cuid())
  userId      String
  question    String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@index([userId])
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  label  String
  votes  Int    @default(0)

  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollVotes PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  voterId   String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voter  User       @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([pollId, voterId])
  @@index([pollId])
  @@index([voterId])
}

/// Recording concurrency control.
///
/// One row per attempt to start recording. `status="active"` slots count
/// against the user's `maxConcurrentRecordings` cap; `status="queued"`
/// slots wait in FIFO order (by `queuePosition`) for a slot to free up.
///
/// `claimedAt` is the time the slot was created (queued or active).
/// `releasedAt` is set when the slot is released — kept around briefly
/// so the server can detect "previous session ended" on the next start.
///
/// The associated `sessionId` is optional because a queued slot may not
/// yet have a Session row (we only create one once the slot is promoted
/// to active and the client is told to proceed).
model RecordingSlot {
  id            String    @id @default(cuid())
  userId        String
  sessionId     String?
  /// "active" — holds a real recording slot; counts against maxConcurrent.
  /// "queued" — waiting for a slot; promoted to "active" when one frees.
  status        String
  /// 1-indexed position in the user's wait line. Only set when status="queued".
  queuePosition Int?
  claimedAt     DateTime  @default(now())
  releasedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

/// Referral codes — reusable, opt-in attribution.
///
/// Any logged-in user can mint a code. Anyone signing up can apply a
/// code (optional; signup never requires one). When a new user
/// signs up with a code we stamp `User.invitedById` and bump
/// `claimCount` here. Same code can be reused by any number of new
/// signups.
///
/// `code` is a short opaque string (alphanumeric, no ambiguous
/// glyphs). `isActive=false` retires a code without deleting it
/// (preserves the attribution chain for users already brought in by
/// it). `expiresAt` lets the inviter time-box a campaign code.
model Invitation {
  id              String    @id @default(cuid())
  code            String    @unique
  createdByUserId String
  /// Optional human-readable label so the inviter can remember
  /// "this code is for the marketing email" or "for Alice".
  note            String?
  /// Soft-disable. When false the code is rejected at /validate even
  /// if it's not expired. Past attributions are kept.
  isActive        Boolean   @default(true)
  expiresAt       DateTime?
  /// How many signups have used this code so far. Maintained by the
  /// createUser hook (auth.ts); not directly writable from the API.
  claimCount      Int       @default(0)
  createdAt       DateTime  @default(now())

  createdBy User @relation("CreatedInvites", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([createdByUserId])
}
