generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  /// NextAuth uses `image` for the OAuth profile picture; we keep our
  /// existing `avatarUrl` alias as well for backwards-compat with code that
  /// reads it. New code should prefer `image`.
  image         String?
  avatarUrl     String?
  /// Free-form per-user UI/notification/floating-window preferences (JSON blob)
  settings      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  folders           Folder[]
  sessions          Session[]
  flashcards        Flashcard[]
  chatSessions      ChatSession[]
  liveShareSessions LiveShareSession[]
  polls             Poll[]
  pollVotes         PollVote[]

  // ---- NextAuth -----------------------------------------------------
  // We use JWT session strategy so there's no separate Session table
  // (which would clash with our existing Session = recording-session
  // model below). Only Account + VerificationToken are needed.
  accounts      Account[]

  // ---- Billing ------------------------------------------------------
  subscription  Subscription?
}

// =========================================================
// NextAuth tables (Auth.js v5 spec)
// =========================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String                   // "oauth" | "email" | "credentials"
  provider          String                   // "google" | "apple" | …
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String                          // email being verified
  token      String                          // opaque magic-link token
  expires    DateTime

  @@unique([identifier, token])
}

// =========================================================
// Billing (mirrors lecsync's structure; see
// docs/LECSYNC_REVERSE_ENGINEERING.md §8 B)
// =========================================================

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model Plan {
  id                       String   @id @default(cuid())
  /// Internal slug, e.g. "free", "business"
  name                     String   @unique
  /// Customer-facing label, e.g. "Free", "Business"
  displayName              String
  description              String?
  monthlyPriceCents        Int      @default(0)
  yearlyPriceCents         Int      @default(0)
  /// Recording-time quota per calendar month. 999999 = effectively unlimited.
  monthlyMinutes           Int      @default(120)
  /// Chat messages per day cap. 0 = unlimited (handled in code).
  dailyChatMessages        Int      @default(20)
  cloudTranslationIncluded Boolean  @default(true)
  isPremium                Boolean  @default(false)
  isActive                 Boolean  @default(true)
  /// Newly registered users get the default plan as their initial Subscription.
  isDefault                Boolean  @default(false)
  /// Stripe price ids (filled in when admin links a plan to Stripe).
  stripePriceIdMonthly     String?
  stripePriceIdYearly      String?
  /// Apple IAP product ids (for the iOS app, if we ship one).
  appleProductIdMonthly    String?
  appleProductIdYearly     String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                       String             @id @default(cuid())
  userId                   String             @unique
  user                     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId                   String
  plan                     Plan               @relation(fields: [planId], references: [id])
  status                   SubscriptionStatus @default(ACTIVE)
  billingCycle             BillingCycle       @default(MONTHLY)
  currentPeriodStart       DateTime           @default(now())
  /// null for default/free plans that don't expire.
  currentPeriodEnd         DateTime?
  cancelAtPeriodEnd        Boolean            @default(false)
  isStripeSubscription     Boolean            @default(false)
  /// "default" (auto on signup) | "stripe" | "apple_iap" | "redemption" | "admin"
  subscriptionSource       String             @default("default")
  stripeSubscriptionId     String?            @unique
  stripeCustomerId         String?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  @@index([planId])
}

model Folder {
  id                   String   @id @default(cuid())
  userId               String
  name                 String
  color                String?
  sourceLang           String?
  targetLang           String?
  /// Serialized list of terms used as Soniox `context` for sessions in this folder
  transcriptionContext String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions  Session[]
  documents Document[]

  @@index([userId])
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  folderId         String?
  title            String   @default("")
  sourceLang       String
  targetLang       String
  status           String   @default("idle") // idle/recording/uploading/ready/error
  durationMs       Int?
  audioPath        String?
  audioContentType String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder            Folder?            @relation(fields: [folderId], references: [id], onDelete: SetNull)
  segments          Segment[]
  speakerNames      SpeakerName[]
  audioChunks       AudioChunk[]
  bookmarks         Bookmark[]
  minutes           Minutes?
  chatSessions      ChatSession[]
  flashcards        Flashcard[]
  liveShareSessions LiveShareSession[]

  @@index([userId])
  @@index([folderId])
  @@index([createdAt])
}

model Segment {
  id             String   @id @default(cuid())
  sessionId      String
  segmentIndex   Int
  audioStartMs   Int
  audioEndMs     Int
  speakerId      Int?
  sourceText     String   @db.Text
  translatedText String?  @db.Text
  confidence     Float?
  isFinal        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, segmentIndex])
  @@index([sessionId])
}

model SpeakerName {
  id        String   @id @default(cuid())
  sessionId String
  speakerId Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, speakerId])
}

model AudioChunk {
  id          String   @id @default(cuid())
  sessionId   String
  chunkIndex  Int
  sizeBytes   Int
  durationMs  Int
  contentType String
  storageKey  String
  publicUrl   String
  uploadedAt  DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, chunkIndex])
  @@index([sessionId])
}

model Bookmark {
  id        String   @id @default(cuid())
  sessionId String
  atMs      Int
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model Minutes {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  contentMd    String   @default("") @db.Text
  sectionsJson Json?
  model        String?
  status       String   @default("pending") // pending/streaming/done/error
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Document {
  id               String   @id @default(cuid())
  folderId         String
  fileName         String
  fileType         String
  fileSize         Int
  storageKey       String
  blobUrl          String
  extractionStatus String   @default("pending") // pending/processing/done/failed
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  folder         Folder          @relation(fields: [folderId], references: [id], onDelete: Cascade)
  extractedTerms ExtractedTerm[]

  @@index([folderId])
}

model ExtractedTerm {
  id         String   @id @default(cuid())
  documentId String
  term       String
  definition String?
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  sessionId String?
  title     String   @default("Untitled")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session  Session?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId])
  @@index([sessionId])
}

model ChatMessage {
  id            String   @id @default(cuid())
  chatSessionId String
  role          String   // user/assistant/system
  content       String   @db.Text
  partsJson     Json?
  createdAt     DateTime @default(now())

  chatSession ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId])
}

model Flashcard {
  id              String   @id @default(cuid())
  userId          String
  sourceSessionId String?
  sourceSegmentId String?
  front           String   @db.Text
  back            String   @db.Text
  intervalDays    Int      @default(0)
  easeFactor      Float    @default(2.5)
  reviewCount     Int      @default(0)
  nextReviewAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session?          @relation(fields: [sourceSessionId], references: [id], onDelete: SetNull)
  reviews FlashcardReview[]

  @@index([userId])
  @@index([nextReviewAt])
}

model FlashcardReview {
  id          String   @id @default(cuid())
  flashcardId String
  rating      Int
  reviewedAt  DateTime @default(now())

  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@index([flashcardId])
}

model LiveShareSession {
  id        String   @id @default(cuid())
  sessionId String
  token     String   @unique
  userId    String
  createdAt DateTime @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
}

model Poll {
  id          String   @id @default(cuid())
  userId      String
  question    String   @db.Text
  description String?  @db.Text
  createdAt   DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  options PollOption[]
  votes   PollVote[]

  @@index([userId])
}

model PollOption {
  id     String @id @default(cuid())
  pollId String
  label  String
  votes  Int    @default(0)

  poll      Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  pollVotes PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String   @id @default(cuid())
  pollId    String
  optionId  String
  voterId   String
  createdAt DateTime @default(now())

  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  voter  User       @relation(fields: [voterId], references: [id], onDelete: Cascade)

  @@unique([pollId, voterId])
  @@index([pollId])
  @@index([voterId])
}
