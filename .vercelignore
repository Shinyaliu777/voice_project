# Local-only artifacts that don't belong in the Vercel build context.

# Local filesystem storage driver output (replaced by R2 in production).
uploads/

# Local Postgres data directory used by docker-compose dev setup.
data/

# Local env overrides — never ship.
*.local.*
.env
.env.local
.env*.local

# Sibling worktrees created during parallel agent development.
../voice_project_*

# Editor / OS noise.
.DS_Store
.idea/
*.log

# Build caches.
.next/
*.tsbuildinfo
