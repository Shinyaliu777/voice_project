# Postgres (docker-compose up postgres)
DATABASE_URL="postgresql://voice:voice@localhost:5432/voice_project"

# Provider keys
SONIOX_API_KEY=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""

# Storage driver: "local" (filesystem) or "s3" (S3-compatible)
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./uploads"
STORAGE_PUBLIC_BASE="/api/audio/file"
# Used only when STORAGE_DRIVER=s3
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE=""

# LLM provider routing
LLM_DEFAULT_PROVIDER="gemini"
LLM_MINUTES_MODEL="gemini-2.5-flash"
LLM_CHAT_MODEL="claude-sonnet-4-6"
LLM_TRANSLATE_MODEL="gemini-2.5-flash"
LLM_TERM_EXTRACT_MODEL="gemini-2.5-flash"
LLM_FLASHCARD_MODEL="gemini-2.5-flash"

# Dev user (no auth in Phase 1)
DEV_USER_EMAIL="dev@voice.local"
DEV_USER_NAME="Dev User"

# Soniox
SONIOX_MODEL="stt-rt-v4"
SONIOX_TOKEN_TTL_SECONDS=600

# Upload chunking
UPLOAD_INTERVAL_MS=3000
TARGET_SAMPLE_RATE=16000

# Redis for multi-instance live-share broadcasting (optional in dev — falls back to in-memory)
REDIS_URL=""
