# ============================================================================
# Voice Project — local dev / single-machine deploy template
#
# Copy to .env (gitignored) and fill in the blanks. For Vercel / managed
# deploys see .env.production.example — same variable set, different
# typical values (e.g. R2 storage, Neon DATABASE_URL).
#
# Stars (*) mark variables that MUST have a real value for the app to
# start cleanly. Everything else has a working default or disables a
# feature gracefully when left blank.
# ============================================================================


# ─── 1. Postgres ───────────────────────────────────────────────────────────
# Docker compose (the bundled one) gives you voice:voice@localhost:5432
DATABASE_URL="postgresql://voice:voice@localhost:5432/voice_project"   # *


# ─── 2. Soniox (real-time STT + translation) ──────────────────────────────
SONIOX_API_KEY=""                          # *
SONIOX_MODEL="stt-rt-v4"
SONIOX_TOKEN_TTL_SECONDS=600

# Strict-mode language hints — refuse to transcribe utterances outside
# the source ↔ target pair (matches lecsync). Default "1" (on). Set to
# "0" if your users code-switch heavily (mix Mandarin/English mid-
# sentence).
NEXT_PUBLIC_SONIOX_LANGUAGE_HINTS_STRICT="1"


# ─── 3. LLM providers (pick at least one) ─────────────────────────────────
GEMINI_API_KEY=""                          # *  — choose
ANTHROPIC_API_KEY=""                       # *  — at least
DEEPSEEK_API_KEY=""                        # *  — one

# Routing: "gemini" | "claude" | "deepseek"
LLM_DEFAULT_PROVIDER="gemini"

# Per-task model overrides (any provider's model id; routed via
# LLM_DEFAULT_PROVIDER unless the id is unambiguous to a provider).
# DeepSeek: "deepseek-v4-flash" (cost-perf) or "deepseek-v4-pro" (reasoning).
# Gemini:   "gemini-2.5-flash-lite", "gemini-2.5-flash", "gemini-2.5-pro".
# Claude:   "claude-haiku-4-5", "claude-sonnet-4-6", "claude-opus-4-7".
LLM_MINUTES_MODEL="gemini-2.5-flash"
LLM_CHAT_MODEL="claude-sonnet-4-6"
LLM_TRANSLATE_MODEL="gemini-2.5-flash"
LLM_TERM_EXTRACT_MODEL="gemini-2.5-flash"
LLM_FLASHCARD_MODEL="gemini-2.5-flash"


# ─── 4. Storage (audio chunks, final mixes, docs) ──────────────────────────
# Local filesystem (recommended for self-host); "s3" for any S3-compatible
# (Cloudflare R2, MinIO, AWS S3).
STORAGE_DRIVER="local"                                   # *
STORAGE_LOCAL_DIR="./uploads"                            # * absolute in prod
STORAGE_PUBLIC_BASE="/api/audio/file"                    # leave as-is

# Only when STORAGE_DRIVER=s3
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE=""


# ─── 5. Upload + capture tuning ────────────────────────────────────────────
UPLOAD_INTERVAL_MS=3000        # MediaRecorder chunk emit interval (ms)
TARGET_SAMPLE_RATE=16000       # Soniox expects 16 kHz


# ─── 6. Authentication (NextAuth / Auth.js v5) ─────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=""                             # *
# Optional — Auth.js reads request Host when blank (we set trustHost: true)
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — fill in for production; leave blank to disable
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Dev-only email login (any email, no password). Defaults ON in
# NODE_ENV=development. Set to "1" to ALSO enable in production —
# only if you have NO Google OAuth configured (boot guard will refuse
# to start if both Google + dev-login are on in prod, since that lets
# anyone log in as any Google user by typing their email).
ALLOW_DEV_LOGIN=""

# Phase-1 fallback (kept around for some unauthed dev smoke tests).
# Leave blank in prod.
DEV_USER_EMAIL="dev@voice.local"
DEV_USER_NAME="Dev User"
ALLOW_DEV_USER_FALLBACK=""


# ─── 7. Referral codes (closed-beta acquisition loop) ──────────────────────
# Each new user who signs up with a referral code gives the inviter N
# bonus monthly recording minutes. Default 60. Set "0" to record
# attribution but pay no bonus.
REFERRAL_BONUS_MINUTES="60"

# Admin console allowlist. Comma-separated emails (case-insensitive).
# Users in this list see /admin in the sidebar and can manage other
# users, issue redemption codes, grant minutes, suspend accounts.
# Once at least one admin exists, you can promote/demote others via
# the /admin UI (User.isAdmin column) — the env list is just to
# bootstrap the first admin without raw SQL.
ADMIN_EMAILS=""


# ─── 8. Redis (optional — only needed for multi-instance) ──────────────────
# Single-instance deploys can leave blank; live-share falls back to
# in-process pub/sub. Multi-instance needs Redis for fan-out across
# Node processes. Upstash works fine.
REDIS_URL=""


# ─── 9. PostHog observability (optional self-hosted) ───────────────────────
# Leave blank to disable analytics entirely. See docs/posthog-deployment.md
# for a step-by-step self-host on the same Linux box.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""


# ─── 10. Server ────────────────────────────────────────────────────────────
# Custom Node server (server.ts) reads PORT; defaults to 3000. NODE_ENV
# is set automatically by `npm run start` ("production") and
# `npm run dev` (left as "development").
PORT=3000
# NODE_ENV is set by the start scripts — don't manually set here unless
# you know why.
